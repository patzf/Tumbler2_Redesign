	)
	(text "LDO after 3.3V buck converter not worth it.\nVCC and VCCA are directly connected inside\nWROOM 1 module. Eather use ESP32 ADC and\ndon't mind, or connect high precition ADC via\npin header to GPIOs or connect with bus. If a\nLDO is still desired, use NCP161 for high PSRR."
		(exclude_from_sim no)
		(at 211.074 108.966 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
